// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MediaType {
  movie
  tv
}

enum DataPrivacy {
  ONLY_ME
  FRIENDS
  EVERYONE
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum NotificationType {
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  COLLECTION_INVITE
}

enum UserActivityType {
  ACCOUNT_CREATED
  ACCOUNT_LOGGED_IN
  ACCOUNT_LOGGED_OUT
  MEDIA_LIKED
  MEDIA_UNLIKED
  MEDIA_WATCHED
  MEDIA_UNWATCHED
  MEDIA_WATCHLISTED
  MEDIA_REMOVED_FROM_WATCHLIST
  COLLECTION_CREATED
  COLLECTION_UPDATED
  COLLECTION_DELETED
  COLLECTION_ITEM_ADDED
  COLLECTION_ITEM_REMOVED
  PROFILE_UPDATED
}

enum UserRole {
  USER
  ADMIN
}

enum CollectionMemberRole {
  VIEWER
  EDITOR
}

enum CollectionInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  REVOKED
}

model User {
  id               String       @id @default(uuid())
  username         String       @unique
  role             UserRole     @default(USER)
  profilePrivacy   DataPrivacy  @default(EVERYONE)
  watchedPrivacy   DataPrivacy  @default(FRIENDS)
  likedPrivacy     DataPrivacy  @default(FRIENDS)
  watchlistPrivacy DataPrivacy  @default(ONLY_ME)
  password         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user_media       UserMedia[]
  collections      Collection[]

  // Friend relationships
  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")

  // Notifications
  notifications      Notification[] @relation("UserNotifications")
  actedNotifications Notification[] @relation("NotificationActor")
  activities         UserActivity[]
  collectionMemberships CollectionMember[] @relation("CollectionMemberUser")
  sentCollectionInvites CollectionInvite[] @relation("CollectionInviteInviter")
  receivedCollectionInvites CollectionInvite[] @relation("CollectionInviteInvitee")

  @@map("users")
}

model Friendship {
  id         String       @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId]) // Prevent duplicate friend requests
  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([status])
  @@map("friendships")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  read        Boolean          @default(false)
  actorId     String?
  referenceId String? // friendshipId, collectionId, etc.
  entityType  String?
  entityId    String?
  dedupeKey   String?
  metadata    String?
  readAt      DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user  User  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([userId, dedupeKey])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

model UserMedia {
  id          String    @id @default(uuid())
  userId      String
  media_id    Int
  media_type  MediaType
  liked       Boolean   @default(false)
  watched     Boolean   @default(false)
  watchlist   Boolean   @default(false)
  likedAt     DateTime?
  watchedAt   DateTime?
  watchlistAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media MediaSnapshot @relation(fields: [media_id, media_type], references: [media_id, media_type], onDelete: Cascade)

  @@unique([userId, media_id, media_type])
  @@index([userId])
  @@index([userId, watched])
  @@index([userId, liked])
  @@index([userId, watchlist])
  @@index([userId, watchedAt])
  @@index([userId, likedAt])
  @@index([userId, watchlistAt])
  @@index([media_id, media_type])
  @@map("user_media")
}

model MediaSnapshot {
  id                String    @id @default(uuid())
  media_id          Int
  media_type        MediaType
  title             String?
  original_title    String?
  overview          String?
  poster_path       String?
  backdrop_path     String?
  vote_average      Float?
  vote_count        Int?
  popularity        Float?
  adult             Boolean?
  genre_ids         String? // Stored as JSON string in SQLite
  release_date      String?
  original_language String?
  runtime           Int?
  status            String?
  firstSyncedAt     DateTime  @default(now())
  lastSyncedAt      DateTime  @updatedAt

  userMedia       UserMedia[]
  collectionItems CollectionItem[]

  @@unique([media_id, media_type])
  @@index([media_type])
  @@index([media_type, popularity])
  @@map("media_snapshots")
}

model UserActivity {
  id           String           @id @default(uuid())
  userId       String
  type         UserActivityType
  media_id     Int?
  media_type   MediaType?
  collectionId String?
  metadata     String?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([media_id, media_type])
  @@index([collectionId])
  @@map("user_activities")
}

model Collection {
  id          String      @id @default(uuid())
  userId      String
  name        String
  description String?
  privacy     DataPrivacy @default(ONLY_ME)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]
  members CollectionMember[]
  invites CollectionInvite[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  id           String    @id @default(uuid())
  collectionId String
  media_id     Int
  media_type   MediaType
  addedByUserId String?

  created_at DateTime @default(now())

  collection Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  media      MediaSnapshot @relation(fields: [media_id, media_type], references: [media_id, media_type], onDelete: Cascade)

  @@unique([collectionId, media_id, media_type]) // Prevent duplicates in same collection
  @@index([collectionId])
  @@index([media_id, media_type])
  @@map("collection_items")
}

model CollectionMember {
  id           String               @id @default(uuid())
  collectionId String
  userId       String
  role         CollectionMemberRole
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User       @relation("CollectionMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
  @@index([userId])
  @@index([collectionId, role])
  @@map("collection_members")
}

model CollectionInvite {
  id           String                 @id @default(uuid())
  collectionId String
  inviterId    String
  inviteeId    String
  role         CollectionMemberRole
  status       CollectionInviteStatus @default(PENDING)
  respondedAt  DateTime?
  revokedAt    DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  inviter    User       @relation("CollectionInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee    User       @relation("CollectionInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([collectionId, inviteeId, status])
  @@index([inviteeId, status])
  @@index([collectionId, status])
  @@map("collection_invites")
}
